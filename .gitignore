## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Auto-generated files
Generated\ Files/

# Build results
[Bb]in/
[Oo]bj/

# VS Code settings
.vscode/

# Rider settings
.idea/

# Publish output
publish/

# .NET Core specific files
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/
!**/packages/repositories.config

# Backup & report files from converting an old project file
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# SQL Server files
*.mdf
*.ldf

# CShapier
.config/

.DS_Store
